{
  "log": { "loglevel": "none" },
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 8080,
      "protocol": "vless",
      "settings": {
        "clients": [
          { "id": "9e507b33-65b6-40a4-b37f-eabad158b645" }
        ],
        "decryption": "none",
        "fallbacks": [
          { "path": "/prvtspyyy", "dest": "@xhttp" },
          { "dest": "@dashboard" }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "none",
        "xhttpSettings": {
          "path": "/prvtspyyy",
          "host": ["*"],
          "method": "GET",
          "maxConnections": 200,
          "maxConcurrentStreams": 200,
          "idleTimeout": 300,
          "pingTimeout": 100
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    },
    {
      "tag": "xhttp",
      "listen": "127.0.0.1",
      "port": 8082,
      "protocol": "vless",
      "settings": { "clients": [], "decryption": "none" },
      "streamSettings": { "network": "xhttp" }
    },
    {
      "tag": "dashboard",
      "listen": "127.0.0.1",
      "port": 8081,
      "protocol": "http",
      "settings": {
        "response": {
          "status": 200,
          "headers": { "Content-Type": ["text/plain", "text/html"] },
          "body": "Prvtspyyy404"
        }
      }
    }
  ],
  "outbounds": [
    { "protocol": "freedom", "settings": { "domainStrategy": "UseIPv4" } }
  ]
}
