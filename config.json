{
  "log": { "loglevel": "none" },
  "dns": {
    "servers": [
      "https+local://94.140.14.14/dns-query", 
      "8.8.8.8",
      "localhost"
    ]
  },
  "inbounds": [
    {
      "port": "PORT_PLACEHOLDER",
      "protocol": "vless",
      "settings": {
        "clients": [{ "id": "9e507b33-65b6-40a4-b37f-eabad158b645" }],
        "decryption": "none",
        "fallbacks": [{ "dest": 8081 }]
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": { "path": "/prvtspyyy" }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"]
      }
    },
    {
      "listen": "127.0.0.1",
      "port": 8081,
      "protocol": "http",
      "settings": {
        "status": 200,
        "headers": { "Content-Type": ["text/plain"] },
        "body": "Service Operational"
      }
    }
  ],
  "outbounds": [
    { "protocol": "freedom", "tag": "direct", "settings": { "domainStrategy": "UseIPv4" } },
    { "protocol": "blackhole", "tag": "blocked" }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "domain": ["geosite:category-ads-all", "geosite:category-ads-ads", "doubleclick.net", "adservice.google.com"],
        "outboundTag": "blocked"
      }
    ]
  }
}
