{
  "log": {
    "loglevel": "warning"
  },
  "dns": {
    "hosts": {
      "geosite:category-ads-all": "127.0.0.1",
      "geosite:category-ads": "127.0.0.1",
      "domain:ads.youtube.com": "127.0.0.1",
      "domain:adservice.google.com": "127.0.0.1",
      "domain:doubleclick.net": "127.0.0.1"
    },
    "servers": [
      "1.1.1.1",
      "8.8.8.8",
      "localhost"
    ]
  },
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": 8080,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "9e507b33-65b6-40a4-b37f-eabad158b645"
          }
        ],
        "decryption": "none",
        "fallbacks": [
          {
            "dest": 8081
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": {
          "path": "/prvtspyyy"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"]
      }
    },
    {
      "listen": "127.0.0.1",
      "port": 8081,
      "protocol": "dokodemo-door",
      "address": "127.0.0.1",
      "followRedirect": false
      }
    }
      "settings": {
        "response": {
          "status": 200,
          "headers": {
            "Content-Type": ["text/plain"]
          },
          "body": "Keep-Alive Active"
        }
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    }
  ],
  "routing": {
    "domainStrategy": "IPOnDemand",
    "rules": [
      {
        "type": "field",
        "outboundTag": "block",
        "domain": [
          "geosite:category-ads-all",
          "geosite:category-ads",
          "domain:ads.youtube.com",
          "domain:adservice.google.com",
          "domain:doubleclick.net",
          "domain:googlesyndication.com",
          "domain:googleadservices.com"
        ]
      },
      {
        "type": "field",
        "outboundTag": "direct",
        "network": "tcp,udp"
      }
    ]
  }
}
