{
  "log": { "loglevel": "none" },
  "dns": {
    "servers": [
      "https+local://dns.adguard-dns.com/dns-query",
      "1.1.1.1",
      "localhost"
    ]
  },
  "inbounds": [
    {
      "port": 8080,
      "protocol": "vless",
      "settings": {
        "clients": [{ "id": "9e507b33-65b6-40a4-b37f-eabad158b645" }],
        "decryption": "none",
        "fallbacks": [{ "dest": 8081 }]
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": { "path": "/prvtspyyy" }
      },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls"] }
    },
    {
      "listen": "127.0.0.1",
      "port": 8081,
      "protocol": "http",
      "settings": {
        "response": {
          "status": 200,
          "headers": { 
            "Content-Type": ["text/html; charset=utf-8"],
            "Server": ["Prvtspyyy404"]
          },
          "body": "<html><body style='background:#000;color:#0f0;font-family:monospace;display:flex;align-items:center;justify-content:center;height:100vh;margin:0'><div style='border:1px solid #0f0;padding:20px'><b>[SERVER]:</b> Prvtspyyy404<br><b>[NETWORK]:</b> SPY404<br><b>[STATUS]:</b> ACTIVE</div></body></html>"
        }
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "settings": { "domainStrategy": "UseIPv4" }
    }
  ]
}
