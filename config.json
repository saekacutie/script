{
  "log": { "loglevel": "none" },
  "dns": {
    "hosts": { "geosite:category-ads-all": "127.0.0.1" },
    "servers": ["https+local://8.8.8.8/dns-query", "1.1.1.1", "localhost"]
  },
  "inbounds": [
    {
      "port": 8080,
      "protocol": "vless",
      "settings": {
        "clients": [{ "id": "9e507b33-65b6-40a4-b37f-eabad158b645" }],
        "decryption": "none",
        "fallbacks": [{ "dest": 8081 }]
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": { "path": "/prvtspyyy" }
      },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls", "quic"] }
    },
    {
      "listen": "127.0.0.1",
      "port": 8081,
      "protocol": "http",
      "settings": {
        "response": {
          "status": 200,
          "headers": { "Content-Type": ["text/plain"], "X-Status": "2000K" },
          "body": "Prvtspyyy404 [Status: 2000K] - AdBlock Active"
        }
      }
    }
  ],
  "outbounds": [
    { "protocol": "freedom", "tag": "direct" },
    { "protocol": "blackhole", "tag": "block" }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "outboundTag": "block",
        "domain": ["geosite:category-ads-all", "geosite:google-ads", "domain:doubleclick.net"]
      }
    ]
  }
}
