{
  "log": { "loglevel": "none" },
  "dns": {
    "servers": ["https+local://dns.google/dns-query", "1.1.1.1"]
  },
  "inbounds": [
    {
      "port": 8080,
      "protocol": "vless",
      "settings": {
        "clients": [{ "id": "9e507b33-65b6-40a4-b37f-eabad158b645" }],
        "decryption": "none",
        "fallbacks": [{ "dest": 8081 }]
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": { "path": "/prvtspyyy" }
      },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls", "quic"] }
    },
    {
      "listen": "127.0.0.1",
      "port": 8081,
      "protocol": "http",
      "settings": {
        "response": {
          "status": 200,
          "headers": { "Content-Type": ["text/html"] },
          "body": "<html><body>PRVTSPYYY ACTIVE</body></html>"
        }
      }
    }
  ],
  "outbounds": [
    { "protocol": "freedom", "tag": "direct" },
    { "protocol": "blackhole", "tag": "block" }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      { "type": "field", "outboundTag": "block", "domain": ["geosite:category-ads-all"] },
      { "type": "field", "outboundTag": "direct", "network": "udp,tcp" }
    ]
  }
}
