{
  "log": { "loglevel": "none" },
  "dns": {
    "servers": [
      "https+local://dns.adguard-dns.com/dns-query",
      "1.1.1.1",
      "localhost"
    ]
  },
  "inbounds": [
    {
      "port": 8080,
      "protocol": "vless",
      "settings": {
        "clients": [{ "id": "9e507b33-65b6-40a4-b37f-eabad158b645" }],
        "decryption": "none",
        "fallbacks": [{ "dest": 8081 }]
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": { "path": "/prvtspyyy" }
      },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls", "quic"] }
    },
    {
      "listen": "127.0.0.1",
      "port": 8081,
      "protocol": "http",
      "settings": {
        "response": {
          "status": 200,
          "headers": { "Content-Type": ["text/html; charset=utf-8"] },
          "body": "<html><body style='background:#000;color:#0f0;font-family:monospace;display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;margin:0'><div style='border:1px solid #0f0;padding:20px'><b>PRVTSPYYY404</b><br>STATUS: ACTIVE<br>MODE: ADGUARD HYBRID<br>LATENCY: <span id='ms'>--</span>ms</div><script>const t=performance.now();fetch(window.location.href).then(()=>{document.getElementById('ms').innerText=Math.round(performance.now()-t);});</script></body></html>"
        }
      }
    }
  ],
  "outbounds": [
    { "protocol": "freedom", "tag": "direct" },
    { "protocol": "dns", "tag": "dns-out" }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      { "type": "field", "port": 53, "outboundTag": "dns-out" },
      { "type": "field", "outboundTag": "direct", "network": "udp,tcp" }
    ]
  }
}
